{
	"cleanUrls": true,
	"trailingSlash": false,
	"rewrites": [
		{ "source": "/", "destination": "/index.html" },
		{ "source": "/login", "destination": "/login.html" },
		{ "source": "/dashboard", "destination": "/dashboard.html" },
		{ "source": "/leaderboard", "destination": "/leaderboard.html" },
		{ "source": "/search", "destination": "/search.html" },
		{ "source": "/css/:path*", "destination": "/src/css/:path*" },
		{ "source": "/js/:path*", "destination": "/src/js/:path*" }
	]
}
